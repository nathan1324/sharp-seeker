# The Odds API
ODDS_API_KEY=your_key_here
ODDS_API_MONTHLY_CREDITS=100000

# Discord — default channel (required)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook

# Per-signal-type channels (optional — falls back to default if not set)
# DISCORD_WEBHOOK_STEAM_MOVE=https://discord.com/api/webhooks/...
# DISCORD_WEBHOOK_RAPID_CHANGE=https://discord.com/api/webhooks/...
# DISCORD_WEBHOOK_PINNACLE_DIVERGENCE=https://discord.com/api/webhooks/...
# DISCORD_WEBHOOK_REVERSE_LINE=https://discord.com/api/webhooks/...
# DISCORD_WEBHOOK_EXCHANGE_SHIFT=https://discord.com/api/webhooks/...
# DISCORD_WEBHOOK_ARBITRAGE=https://discord.com/api/webhooks/...

# Per-sport+signal webhook overrides (JSON object)
# Routes a specific signal type for a specific sport to its own channel
# Keys: "signal_type:sport_key", values: webhook URL
# DISCORD_WEBHOOK_OVERRIDES={"pinnacle_divergence:basketball_ncaab": "https://discord.com/api/webhooks/..."}

# Dedicated raw-data PD channels — when set, ALL PD signals for that sport route
# here and BYPASS the qualifier gate (Best Combo / Best Hour / Edge Hold).
# Used for data-collection on sports without trusted combos/hours yet.
# DISCORD_WEBHOOK_PINNACLE_DIVERGENCE_WNBA=https://discord.com/api/webhooks/...
# DISCORD_WEBHOOK_PINNACLE_DIVERGENCE_MLB=https://discord.com/api/webhooks/...

# When true, every Steam Move alert prepends `@here <@&MEMBER_ROLE_ID>` so the
# channel pings online members and the @member role. Off by default; flip when
# ready. Steam-only by design — keeps notification noise minimal for the most
# trusted signal type.
# DISCORD_STEAM_MENTION_HERE=false
# Override the role ID mentioned alongside @here on Steam/Arb alerts. Default is
# the @member role in the Sandbox Sports server (944472531631472640).
# DISCORD_STEAM_MENTION_ROLE_ID=944472531631472640
# Every Arbitrage alert pings @here + the @member role. On by default — arbs are
# rare and guaranteed-profit, so they always notify. Set false to silence.
# DISCORD_ARB_MENTION_HERE=true

# Polling
POLL_INTERVAL_MINUTES=12
SPORTS=["basketball_nba","basketball_wnba","basketball_ncaab","icehockey_nhl","baseball_mlb"]
BOOKMAKERS=["draftkings","fanduel","betmgm","pinnacle","williamhill_us","betrivers","fanatics","hardrockbet","espnbet"]

# Quiet hours — skip polling during this UTC window to save credits
# Default: 1-13 UTC = 6pm-6am MT
QUIET_HOURS_START=1
QUIET_HOURS_END=13

# Detection — steam moves
STEAM_MIN_BOOKS=3
STEAM_WINDOW_MINUTES=30

# Detection — rapid changes (hold displayed on embeds, no strength boost)
RAPID_SPREAD_THRESHOLD=1.0
RAPID_ML_THRESHOLD=20

# Detection — arbitrage
# Exclude books users can't bet on from arb detection (JSON array)
ARB_EXCLUDED_BOOKS=["pinnacle"]
# Minimum guaranteed-profit % for an arb to alert. 0.0 = surface every arb.
# Arbs are EXEMPT from MIN_SIGNAL_STRENGTH (arb strength = profit%/10, so the
# 0.5 default would require a ~5% arb to pass) — this is their only volume gate.
ARB_MIN_PROFIT_PCT=0.0

# Detection — Pinnacle divergence
# Strength formula: min(1.0, delta/(threshold*3))
# Hold metrics displayed on embeds for analytics but do NOT affect strength.
PINNACLE_SPREAD_THRESHOLD=1.0
PINNACLE_TOTALS_THRESHOLD=1.0
PINNACLE_ML_PROB_THRESHOLD=0.03
# Exclude specific books from Pinnacle divergence detection (JSON array)
# BetMGM lines are slow to update — "divergence" often reflects staleness, not value.
# Caesars (williamhill_us) is notably sharp — PD divergences are noise, not edges (MLB: 2-8-1, -10.4u).
PD_EXCLUDED_BOOKS=["betmgm", "williamhill_us"]
# Per-sport book exclusions — applied IN ADDITION to PD_EXCLUDED_BOOKS (JSON object).
# DraftKings as a PD value book on MLB totals: 25% WR, -86.8u over 155 signals
# (all-time, scripts/analyze_pd_by_book_sport.py 2026-04-25). DK is profitable
# on NBA/NCAAB/NHL (+45.5u combined), so the exclusion is MLB-only.
PD_SPORT_EXCLUDED_BOOKS={"baseball_mlb": ["draftkings"]}
# Per-sport threshold overrides
# ML: kept at global 3% — lower sport overrides (NHL 1.5%, NBA 2%) generated noise.
PD_SPORT_ML_PROB_OVERRIDES={}
# Totals: 0.5 for NHL/NBA/MLB/WNBA — tight totals ranges benefit from lower threshold.
# WNBA added 2026-05-31 by analogy to NBA (no WNBA data yet; revisit at 2026-06-15).
# MLB kept out of best combos (no free plays) but signals still fire to Discord for monitoring.
PD_SPORT_TOTALS_OVERRIDES={"icehockey_nhl": 0.5, "basketball_nba": 0.5, "baseball_mlb": 0.5, "basketball_wnba": 0.5}
# Spreads: 0.5 for NBA/WNBA. WNBA added 2026-05-31 by analogy.
PD_SPORT_SPREAD_OVERRIDES={"basketball_nba": 0.5, "basketball_wnba": 0.5}

# Detection — exchange monitor
EXCHANGE_SHIFT_THRESHOLD=0.05

# Minimum signal strength to alert (0.0–1.0, filters out weak/noisy signals)
MIN_SIGNAL_STRENGTH=0.5

# Per-signal-type minimum strength overrides (JSON object)
# Raises the bar for noisier signal types. Overrides global MIN_SIGNAL_STRENGTH.
SIGNAL_STRENGTH_OVERRIDES={"rapid_change": 0.65, "reverse_line": 0.65}

# Per-signal-type MAXIMUM strength cap — drop signals at/above this threshold (JSON object)
# Filters out "trap" signals with suspiciously high strength. Only listed types are capped.
MAX_SIGNAL_STRENGTH_OVERRIDES={"pinnacle_divergence": 0.80, "rapid_change": 0.80, "reverse_line": 0.80, "steam_move": 0.80}

# Per-signal-type + market minimum strength overrides (JSON object)
# Compound keys: "signal_type:market_key" — raises the bar for specific markets.
# Lookup priority: market override > sport override > type override > global MIN_SIGNAL_STRENGTH
SIGNAL_MARKET_STRENGTH_OVERRIDES={"pinnacle_divergence:spreads": 0.40}

# Per-signal-type + sport minimum strength overrides (JSON object)
# Compound keys: "signal_type:sport_key" — lowers the bar for PD on NHL/NBA/MLB/WNBA.
# Low-strength PD signals were +22.1u (63%) during the stable period.
# WNBA added 2026-05-31 by analogy to NBA (no WNBA data yet; revisit at 2026-06-15).
SIGNAL_SPORT_STRENGTH_OVERRIDES={"pinnacle_divergence:icehockey_nhl": 0.25, "pinnacle_divergence:basketball_nba": 0.25, "pinnacle_divergence:baseball_mlb": 0.25, "pinnacle_divergence:basketball_wnba": 0.25}

# Per-signal-type quiet hours — suppress specific signals at bad-performing UTC hours (JSON object)
# Values are lists of UTC hours (0-23) when that signal type should be suppressed.
# PD: added UTC 17,18 (10-11 AM MST) — consistently worst hours across both periods
# PD MLB: [12, 13] = 5-6 AM MST overnight bleed bucket (see Change Log 2026-05-31:
#   May n=149, 42.7% WR, -38.94u — entire MLB PD May loss concentrated here).
#   Sport-specific key overrides (not merges with) global.
SIGNAL_QUIET_HOURS={"pinnacle_divergence": [3, 4, 14, 17, 18, 20, 22], "pinnacle_divergence:baseball_mlb": [12, 13], "steam_move": [0, 1, 2, 3, 13, 22], "rapid_change": [3, 13, 16, 17, 21], "reverse_line": [1]}

# Signal blocklist — block specific type:market or type:sport:market combos (JSON array)
# 2-key ("steam_move:h2h") blocks across all sports. 3-key ("rapid_change:basketball_ncaab:h2h") blocks one sport.
SIGNAL_BLOCKLIST=["steam_move:h2h", "reverse_line:totals", "rapid_change:basketball_ncaab:h2h"]

# Signal best combos — data-driven from stable period (Mar 3-14, +49.4u).
# 3-key patterns only: "signal_type:sport_key:market_key"
# PD: NBA totals/spreads, NCAAB ML/spreads, NHL totals/ML
# Rapid: NCAAB spreads/totals
# Steam: NBA spreads, MLB totals (63% WR, 20W/12L as of Apr 14)
# RevLine: removed (insufficient sample)
# MLB PD: removed — proven loser (-38u over 4 weeks, 46-51% WR at -110 juice)
SIGNAL_BEST_COMBOS=["pinnacle_divergence:basketball_nba:totals", "pinnacle_divergence:basketball_nba:spreads", "pinnacle_divergence:basketball_ncaab:h2h", "pinnacle_divergence:basketball_ncaab:spreads", "pinnacle_divergence:icehockey_nhl:totals", "pinnacle_divergence:icehockey_nhl:h2h", "rapid_change:basketball_ncaab:spreads", "rapid_change:basketball_ncaab:totals", "steam_move:basketball_nba:spreads", "steam_move:baseball_mlb:totals"]

# Signal best hours — data-driven from stable period (Mar 3-14).
# Keys: "signal_type" (global fallback) or "signal_type:sport_key" (sport-specific, takes priority)
# Sport-specific empty arrays block the global fallback (keeps that sport suppressed).
# PD: 5,6,8,9 AM + 12,2,4,5 PM MST
# Rapid: 7-10 AM + 12,5 PM MST
# Steam: 10,11 AM MST (retuned 2026-06-11 — see below)
# MLB PD totals best hours [9,12,16] MST added 2026-06-11: sent-only 60d analysis
# showed the market at 61% / +29.88u; these 3 hours were the highest-conviction
# (71-77% WR). MLB rapid stays [] (no data). Re-validate the MLB hours in a few wks.
# Steam hours retuned [9,11,13,14] -> [10,11] on 2026-06-11: sent-only 60d
# (analyze_signal_hours.py steam_move 60) showed hour 9 was the WORST hour
# (44%/-5.12u), 13/14 flat; only 10 (64%) and 11 (62%) cleared the bar. NOTE:
# steam's real bleed is market/sport (spreads -15.9u, NBA/WNBA neg) not hours.
SIGNAL_BEST_HOURS={"pinnacle_divergence": [5, 6, 8, 9, 12, 14, 16, 17], "pinnacle_divergence:baseball_mlb": [9, 12, 16], "rapid_change": [7, 8, 9, 10, 12, 17], "rapid_change:baseball_mlb": [], "steam_move": [10, 11]}

# Alert dedup cooldown (minutes)
ALERT_COOLDOWN_MINUTES=60

# Database path (default: sharp_seeker.db, set to /app/data/sharp_seeker.db in Docker)
# DB_PATH=sharp_seeker.db

# Card image output directory (default: data/cards)
# CARD_OUTPUT_DIR=data/cards

# ── X (Twitter) — optional, tweets when signals fire ────────
# Apply for a free developer account at https://developer.x.com
# X_CONSUMER_KEY=your_consumer_key
# X_CONSUMER_SECRET=your_consumer_secret
# X_ACCESS_TOKEN=your_access_token
# X_ACCESS_TOKEN_SECRET=your_access_token_secret
# Free play caps — regulate volume without changing signal logic.
# Caps: 0 = unlimited. Interval: post every Nth eligible signal (1 = post all).
# Current policy (2026-06-06): every Discord-sent PD totals signal is tweeted
# with no throttling — so all three are wide open.
X_FREE_PLAY_SPORT_CAP=0
X_FREE_PLAY_HOURLY_CAP=0
X_FREE_PLAY_INTERVAL=1
# UTC hours when teaser tweets are allowed (JSON array, empty = always)
# Free play tweets always send regardless. MST reference:
# [0, 15, 18, 19, 23] = 5pm prev day, 8am, 11am-12pm, 4pm MST
X_TEASER_HOURS=[0, 15, 18, 19, 23]
# Skip PD signals >= this strength for X tweets (0.0–1.0, default 1.0 = no cap)
X_MAX_STRENGTH=0.80
# Signal types eligible for X tweets (JSON array)
# These types get teasers and count toward the free play interval.
X_TWEET_SIGNAL_TYPES=["pinnacle_divergence", "rapid_change"]
# Free play combo whitelist — only these type:sport:market combos become free plays.
# A `*` in any segment is a wildcard, e.g. "pinnacle_divergence:*:totals" matches
# PD totals in every sport. All free plays still pass the 1+ qualifier gate (the
# same bar Discord uses to send the main alert), so wildcards only widen the
# sport net — they never bypass quality.
# Policy (2026-06-06): every Discord-sent Pinnacle Divergence TOTALS signal is
# tweeted as a free play ("pinnacle_divergence:*:totals"), with no throttling.
# Only PD totals — other signal types (steam, rapid) are NOT sent. PD spreads and
# PD moneyline (h2h) are held OUT while those markets are still under study.
# When ready, re-enable via "pinnacle_divergence:*:h2h" / ":spreads" (spread
# free plays are still code-enforced to Steam type only).
# Empty list = no free plays posted.
X_FREE_PLAY_COMBOS=["pinnacle_divergence:*:totals"]
# Sport keys benched OUT of free plays even when they match a combo above
# (JSON array). Lets you park an entire sport whose edge is still under test
# without touching the wildcard. Empty list = no exclusions.
# (WNBA was fully benched here 2026-06-06; replaced 2026-06-10 by the precise
# WNBA-totals combo exclusion below — see X_FREE_PLAY_EXCLUDED_COMBOS.)
X_FREE_PLAY_EXCLUDED_SPORTS=[]
# type:sport:market combos carved OUT of free plays even when they match a combo
# above (JSON array, same `*` wildcard syntax). Drops ONE market for ONE sport
# while the blanket "pinnacle_divergence:*:totals" still serves the others.
# WNBA totals added 2026-06-10: June PD totals were 8-12 / -5.47u (40% WR) — no
# edge across two looks (50% in the 06-06 backtest, 40% in June), so it stays off
# X. WNBA's edge is in spreads (9-5, +3.26u), which are held out separately by the
# Steam-only-spreads rule. Empty list = no exclusions.
X_FREE_PLAY_EXCLUDED_COMBOS=["pinnacle_divergence:basketball_wnba:totals"]
# Exclude specific books from X free play tweets (JSON array)
# Signals from these books won't be chosen as the free play pick.
X_EXCLUDED_BOOKS=["betmgm"]
# Digest mode: batch teasers into one tweet every N hours (0 = tweet per signal)
X_DIGEST_INTERVAL_HOURS=2

# Logging
LOG_LEVEL=INFO

# ── Scheduled Jobs ──────────────────────────────────────────────
# Signal grading runs at 11:30 UTC (5:30 AM MDT) — grades yesterday's games
# Free play recap tweet at 11:45 UTC (5:45 AM MDT) — after grading
# Daily results cards at 11:46 UTC (5:46 AM MDT) — after recap
# Daily report runs at 11:45 UTC (5:45 AM MDT) — after grading completes
# Weekly report runs Mon 11:45 UTC (5:45 AM MDT)
# Weekly free play recap tweet at 17:00 UTC (11:00 AM MDT) on Sundays
# Budget summary runs at 00:00 UTC (6 PM MDT prev day)
